# Agent Team 配置文件
# 复制此文件为 f:\agents\Demox-main\team\.env 并填写

# ── 必填：API Key（二选一）──────────────────
# ANTHROPIC_API_KEY=sk-ant-your-key-here
#  或
# AGENT_TEAM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1   # 无自定义 base URL 可省略

# ── coding-web 默认配置 ─────────────────────
# CODING_WEB_BASE_URL=https://api.deepseek.com
# CODING_WEB_MODEL=deepseek-v4-flash
# CODING_WEB_MAX_TOKENS=4096
